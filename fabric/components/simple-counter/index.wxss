/* components/simple-counter/index.wxss */
.counter-container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  background-color: #ffffff;
}

.counter-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.counter-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 15px;
}

.decrease-btn {
  background-color: rgba(255, 255, 255, 0.8);
}

.increase-btn {
  background-color: rgba(255, 255, 255, 0.8);
}

.counter-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 128rpx;
  position: relative;
}

.counter-value {
  font-size: 26px;
  min-width: 40px;
  text-align: center;
}

/* 上/下箭头按钮 */
.nav-btn {
  position: absolute;
  bottom: 0;
  left: -96rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn-right {
  left: auto;
  right: -96rpx;
}

.nav-btn image {
  width: 60rpx;
  height: 60rpx;
}

.counter-btn image {
  width: 64rpx;
  height: 64rpx;
}

/* 点击反馈 */
.counter-btn-hover {
  opacity: 0.7;
}

.btn-hover {
  opacity: 0.7;
}

/* ========== 首次操作提示（长按重置） ========== */

.reset-tip {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.75);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  z-index: 99999;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.reset-tip-text {
  font-size: 24rpx;
  color: #fff;
  line-height: 1.4;
}

.reset-tip-dismiss {
  font-size: 22rpx;
  color: #A889C8;
  font-weight: 500;
  line-height: 1.4;
  white-space: nowrap;
}

.reset-tip-arrow {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: -10rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 10rpx solid rgba(0, 0, 0, 0.75);
}

/* 修改计数弹窗样式 */
.modal-content {
  margin: 40rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.modal-content-input {
  width: 100%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  box-sizing: border-box;
}

/* iPad 适配：输入框高度调整 */
@media (min-width: 750px) {
  .modal-content {
    margin: 20px;
    padding: 10px;
  }

  .modal-content-input {
    height: 30px;
    line-height: 30px;
  }
}

/* ========== 计数器-标尺联动激活态 ========== */

/* +/- 按钮：紫色背景提示联动已激活 */
.counter-btn-linked {
  background-color: rgba(106, 13, 173, 0.1) !important;
  border: 2rpx solid rgba(106, 13, 173, 0.2);
}

/* ↑↓ 按钮：紫色背景提示联动已激活 */
.nav-btn-linked {
  background-color: rgba(106, 13, 173, 0.1) !important;
  border: 2rpx solid rgba(106, 13, 173, 0.2);
}
