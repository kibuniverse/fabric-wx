/* components/simple-counter/index.wxss */
.counter-container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  background-color: #ffffff;
}

.counter-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.counter-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 15px;
}

.decrease-btn {
  background-color: #f0f0f0;
}

.increase-btn {
  background-color: #f0f0f0;
}

.counter-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 128rpx;
}

.counter-value {
  font-size: 26px;
  min-width: 40px;
  text-align: center;
}

.memo-btn {
  position: absolute;
  bottom: 0;
  left: -96rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.memo-btn image {
  width: 44rpx;
  height: 44rpx;
}

.reset-btn {
  position: absolute;
  bottom: 0;
  right: -96rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reset-btn image {
  width: 32rpx;
  height: 32rpx;
}

.counter-btn image {
  width: 64rpx;
  height: 64rpx;
}

/* 修改计数弹窗样式 */
.modal-content {
  margin: 40rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.modal-content-input {
  width: 100%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  box-sizing: border-box;
}

/* iPad 适配：输入框高度调整 */
@media (min-width: 750px) {
  .modal-content {
    margin: 20px;
    padding: 10px;
  }

  .modal-content-input {
    height: 30px;
    line-height: 30px;
  }
}
