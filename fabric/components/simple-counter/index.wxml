<!-- components/simple-counter/index.wxml -->
<view class="counter-container" style="background-color: {{backgroundColor}};">
  <view class="counter-main">
    <view class="counter-btn decrease-btn {{linked ? 'counter-btn-linked' : ''}}" hover-class="counter-btn-hover" bindtap="decreaseCount">
      <image src="/assets/minus.svg" mode="aspectFit"></image>
    </view>
    <view class="counter-center" bindtap="onCountTap" bindlongpress="onCountLongPress">
      <animate-numbers value="{{count}}" min='{{0}}' max='{{999}}' options='{{options}}' />
      <!-- 首次操作提示：长按可以重置计数 -->
      <view wx:if="{{showResetTip}}" class="reset-tip" style="top: {{resetTipTop}}px;" catchtap="">
        <text class="reset-tip-text">长按可以重置计数哦～</text>
        <text class="reset-tip-dismiss" catchtap="onResetTipDismiss">我知道了</text>
        <view class="reset-tip-arrow"></view>
      </view>
    </view>
    <view class="counter-btn increase-btn {{linked ? 'counter-btn-linked' : ''}}" hover-class="counter-btn-hover" bindtap="increaseCount">
      <image src="/assets/plus.svg" mode="aspectFit"></image>
    </view>
  </view>
  <!-- 上箭头按钮（左下角） -->
  <view class="nav-btn {{linked ? 'nav-btn-linked' : ''}}" hover-class="btn-hover" bindtap="onUpTap">
    <image src="/assets/up.svg" mode="aspectFit"></image>
  </view>
  <!-- 下箭头按钮（右下角） -->
  <view class="nav-btn nav-btn-right {{linked ? 'nav-btn-linked' : ''}}" hover-class="btn-hover" bindtap="onDownTap">
    <image src="/assets/down.svg" mode="aspectFit"></image>
  </view>

</view>

<!-- 修改当前行数弹窗 -->
<van-dialog
  use-slot
  z-index="10000"
  title="修改当前行数"
  transition="fade"
  show="{{ showModifyCount }}"
  show-cancel-button
  bind:close="closeModifyCountModal"
  bind:confirm="confirmModifyCount"
  confirm-button-color="#A889C8"
>
  <view class="modal-content">
    <input type="number" class="modal-content-input" placeholder="请输入新的行数" value="{{modifyCountInput}}" bindinput="onModifyCountInput" focus="{{showModifyCount}}" maxlength="3" />
  </view>
</van-dialog>
