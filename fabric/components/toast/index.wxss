/* 遮罩层 - 居中定位 */
.toast-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

/* 卡片主体 */
.toast-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 64rpx 40rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  box-shadow:
    0 8rpx 32rpx rgba(106, 13, 173, 0.08),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  backdrop-filter: blur(20px);
  min-width: 200rpx;
  max-width: 500rpx;
}

/* 纯文本模式 (icon=none) 的卡片 */
.toast-card:not(:has(.toast-icon-wrapper)) {
  padding: 28rpx 48rpx;
  background: rgba(255, 255, 255, 0.88);
}

/* 显示/隐藏动画 */
.toast-visible {
  opacity: 1;
  visibility: visible;
  transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1),
              visibility 0s;
}

.toast-hidden {
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
              visibility 0s 0.3s;
}

/* 进入时的缩放动画 */
.toast-visible.toast-entered .toast-card {
  transform: scale(1);
}

.toast-visible:not(.toast-entered) .toast-card {
  transform: scale(1.08);
}

.toast-card {
  transform: scale(0.85);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ====== 成功图标 - 对勾 ====== */
.toast-icon-wrapper {
  margin-bottom: 24rpx;
}

.checkmark-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #A889C8, #7B5EA7);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.checkmark {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  transform: rotate(-45deg);
}

/* 对勾的竖线部分 */
.checkmark-stem {
  position: absolute;
  left: 4rpx;
  bottom: 8rpx;
  width: 6rpx;
  height: 20rpx;
  background: #fff;
  border-radius: 3rpx;
}

/* 对勾的横线部分 */
.checkmark-kick {
  position: absolute;
  left: 4rpx;
  bottom: 8rpx;
  width: 24rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 3rpx;
}

/* ====== 错误图标 - X ====== */
.error-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8A0A0, #C86A6A);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.error-x {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

.error-line-left {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 28rpx;
  height: 5rpx;
  background: #fff;
  border-radius: 3rpx;
  transform: translate(-50%, -50%) rotate(45deg);
}

.error-line-right {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 28rpx;
  height: 5rpx;
  background: #fff;
  border-radius: 3rpx;
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* ====== 文本样式 ====== */
.toast-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  line-height: 1.5;
  word-wrap: break-word;
}

.toast-text-with-icon {
  font-size: 30rpx;
  font-weight: 600;
  color: #212121;
}
