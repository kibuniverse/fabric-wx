<view class="counter-wrapper">
  <!-- 标题和目标行数 -->
  <view class="counter-header">
    <view class="counter-name-wrapper" bindtap="handleClickModifyCounterName" bind:showModifyName="handleShowModifyName">
      <text class="counter-name">{{counterData.name || '默认计数器'}}</text>
      <image class='edit-icon' src="/assets/edit.svg" />
    </view>
    <view class="target-count" bindtap="showTargetInput" bind:showTargetInput="handleShowTargetInput">
      <view class="target-label">目标行数：</view>
      <view class="target-num">{{counterData.targetCount}}</view>
    </view>
  </view>
  <!-- 计数器主体 -->
  <view class="counter-main">
    <view class="counter-btn minus" hover-class="counter-btn-hover" bindtap="decrease" data-isFromChildCounter="false">
      <image class='minus-icon' src="/assets/minus.svg" />
    </view>
    <view class="counter-number" bindtap="handleClickModifyCount" bind:showModifyCount="handleShowModifyCount">
      <animate-numbers value="{{counterData.currentCount}}" min='{{0}}' max='{{999}}' options='{{options}}' />
    </view>
    <view class="counter-btn plus" hover-class="counter-btn-hover" bindtap="increase" data-isFromChildCounter="false">
      <image class='plus-icon' src="/assets/plus.svg" />
    </view>
  </view>
  <!-- 计时器显示 -->
  <view class="timer-display">{{timerDisplay}}</view>
  <!-- 操作按钮 -->
  <view class="operation-buttons">
    <view class="operation-buttons-left">
      <block wx:if="{{showDeleteBtn}}">
        <view class="counter-delete-btn" bindtap="handleCounterDelete">
          <image class="delete-icon" src="/assets/delete.svg" />
          <view class="delete-text">删除计数器</view>
        </view>
      </block>
    </view>
    <view class="operation-buttons-right">
      <view class="operation-btn memo {{hasMemo ? 'memo-active' : ''}}" bindtap="handleMemoClick">
        <image class="memo-icon" src="{{hasMemo ? '/assets/memorandum_colorful.svg' : '/assets/memorandum.svg'}}" />
      </view>
      <view class="operation-btn timer {{isSmartTimerOn ? 'timer-start' : 'timer-stop'}} {{isTimerRunning ? 'timer-counting' : ''}}" bindtap="toggleTimer">
        <image class="timer-icon" src="{{isSmartTimerOn ? '/assets/clock_colorful.svg' : '/assets/clock.svg'}}" />
      </view>
      <view class="operation-btn reset" bindtap="showResetConfirm" bindlongpress="onResetLongPress">
        <image class="reset-icon" src="/assets/reset.svg" />
      </view>
      <!-- 重置按钮引导气泡 -->
      <view class="reset-guide {{showResetGuide ? 'show' : ''}}" catchtap="hideResetGuide">
        <view class="reset-guide-content">
          <text>长按可重置计时</text>
          <text class="reset-guide-confirm">我知道了</text>
        </view>
        <view class="reset-guide-arrow"></view>
      </view>
    </view>
  </view>
  <!-- 历史记录 -->
  <view class="history-section">
    <block wx:if="{{counterData.history.length > 0}}">
      <scroll-view scroll-y class="history-list" id="historyList" scroll-top="{{historyScrollTop}}">
        <block wx:for="{{counterData.history}}" wx:key="index">
          <view class="history-item {{item.isNew ? 'slide-in' : ''}}">
            <view class="history-time">{{item.time}}</view>
            <view class="history-action">{{item.action}}</view>
            <view class="history-count">第{{item.count}}行</view>
            <view class="history-interval">{{item.interval || '--'}}</view>
          </view>
        </block>
        <view class="history-bottom-shadow"></view>
      </scroll-view>
    </block>
    <view wx:else class="history-empty">
      <image src="/assets/history_empty.png" mode="aspectFit" class="empty-image"></image>
    </view>
  </view>
  <van-dialog z-index="10000" id="van-dialog" confirm-button-color="#A889C8" />
</view>