.counter-wrapper {
  padding: 56rpx 44rpx 0 44rpx;
  /* height: calc(100vh - 500rpx); */
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-top: 2rpx solid #0000001a;
  position: relative;
}

/* 头部样式 */
.counter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 120rpx;
  width: 100%;
}

.counter-name-wrapper {
  display: flex;
  align-items: center;
}


.counter-name {
  max-width: 320rpx;
  font-size: 32rpx;
  font-weight: 400;
  line-height: 44rpx;
  letter-spacing: -0.86rpx;
  color: #00000066;
}

.edit-icon {
  width: 32rpx;
  height: 32rpx;
  color: var(--main-default-gray);
  margin-left: 8rpx;
}

.counter-delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 46rpx;
  height: 45rpx;
  margin-right: 20rpx;
}

.delete-text {
  font-weight: 400;
  font-size: 28rpx;
  line-height: 44rpx;
  letter-spacing: -0.86rpx;
  color: #b22222e5;
}

/* 计数器主体样式 */
.counter-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  margin-left: 16rpx;
  margin-right: 16rpx;
}

.counter-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  color: #a889c8;
}

.minus {
  background: #0000001a;
}

.minus-icon {
  width: 96rpx;
  height: 96rpx;
}

.plus {
  background: var(--main-bg-color);
}

.plus-icon {
  width: 96rpx;
  height: 96rpx;
}

.counter-number {
  color: #000000;
}

.number-container {
  position: relative;
  width: 100%;
  height: 100%;
}

/* 计时器显示 */
.timer-display {
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 44rpx;
  letter-spacing: -0.86rpx;
  color: var(--main-default-gray);
  margin-bottom: 52rpx;
}

/* 操作按钮 */
.operation-buttons {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
}

.operation-buttons-left {
  display: flex;
  align-items: center;
}

.operation-buttons-right {
  display: flex;
  align-items: center;
  gap: 48rpx;
  position: relative;
}

.target-count {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.target-label {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 44rpx;
  letter-spacing: -0.86rpx;
  color: #333333;
}

.target-num {
  font-size: 40rpx;
  font-weight: 500;
  line-height: 44rpx;
  letter-spacing: -0.86rpx;
  color: var(--main-color);
}

.operation-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 80rpx;
  height: 80rpx;
  border-radius: 19998rpx;

}

.memo-icon {
  width: 48rpx;
  height: 48rpx;
}


.memo {
  background-color: #0000001a;
}
.memo-active {
  background-color: var(--main-bg-color);
}

.reset {
  background-color: var(--main-bg-color);
}

.reset-icon {
  width: 42rpx;
  height: 42rpx;
}

.timer-icon {
  width: 37rpx;
  height: 42rpx;
}


.timer-start {
  background-color: var(--main-bg-color);
}

.timer-stop {
  background-color: #0000001a;
}

/* 计时中的脉冲动画 */
.timer-counting {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(168, 137, 200, 0.4);
  }
  50% {
    box-shadow: 0 0 0 12rpx rgba(168, 137, 200, 0);
  }
}

/* 重置按钮引导气泡 */
.reset-guide {
  position: absolute;
  right: 0;
  bottom: 100rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
  pointer-events: none;
  z-index: 100;
}

.reset-guide.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.reset-guide-content {
  background-color: rgba(0, 0, 0, 0.75);
  color: #fff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.reset-guide-confirm {
  color: #A889C8;
  font-weight: 500;
}

.reset-guide-arrow {
  position: absolute;
  right: 30rpx;
  bottom: -12rpx;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 14rpx solid rgba(0, 0, 0, 0.75);
}

/* 历史记录部分 */
.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 0rpx 30rpx;
  position: relative;
}

::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  background: transparent !important;
}

/* 微信小程序 scroll-view 隐藏滚动条 */
scroll-view {
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

scroll-view::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  background: transparent !important;
}

.history-list {
  height: 476rpx;
  overflow-y: auto;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 0rpx;
}

.history-items-container {
  position: relative;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0rpx;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0;
  color: #666;
  border-bottom: 2rpx solid #0000001a;
  position: relative;
  transform: translateX(0);
  opacity: 1;
  will-change: transform, opacity;
  justify-content: space-between;
}


.history-item:first-child {
  border-top: 2rpx solid #0000001a;
}

.history-item.slide-in {
  animation: slideInFromRight 0.3s ease-out;
}

@keyframes slideInFromRight {
  0% {
    opacity: 0;
    transform: translateX(100%);
  }

  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

.history-time {
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0;
  color: #00000066;
  white-space: nowrap;
  text-align: center;
  width: 120rpx;
  flex-shrink: 0;
}

.history-action {
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0;
  color: #00000066;
  white-space: nowrap;
  text-align: center;
  width: 80rpx;
  flex-shrink: 0;
}

.history-item:first-child .history-action {
  color: var(--main-color);
}

.history-item:first-child .history-time {
  color: var(--main-color);
}

.history-item:first-child .history-count {
  color: var(--main-color);
}

.history-item:first-child .history-interval {
  color: var(--main-color);
}

.history-count {
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0;
  color: #00000066;
  white-space: nowrap;
  text-align: center;
  width: 80rpx;
  flex-shrink: 0;
}

.history-interval {
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0;
  color: #00000066;
  white-space: nowrap;
  text-align: center;
  width: 100rpx;
  flex-shrink: 0;
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 0 40rpx 0;
}

.empty-image {
  width: 360rpx;
  height: 360rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

.empty-history {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}

.modal-content {
  margin: 40rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.modal-content-input {
  width: 100%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  box-sizing: border-box;
}

/* iPad 适配：输入框高度调整 */
@media (min-width: 750px) {
  .modal-content {
    margin: 20px;
    padding: 10px;
  }

  .modal-content-input {
    height: 30px;
    line-height: 30px;
  }
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #a889c8;
  color: #fff;
}

/* 调整mp-dialog位置，避免被键盘遮挡 */
.weui-dialog {
  transform: translateY(-30vh);
  position: fixed;
  z-index: 5000;
}

/* 确保弹窗内容在移动后也居中显示 */
.weui-dialog__bd {
  padding: 0 30rpx 30rpx;
  min-height: 80rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-all;
  color: #000000;
}

