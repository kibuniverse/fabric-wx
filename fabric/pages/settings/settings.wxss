.container {
  padding-top: 48rpx;
  padding-left: 44rpx;
  padding-right: 44rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #E6E6FA 0%, #FFFFFF 100%);
  box-sizing: border-box;
}

.settings-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
  height: 222rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

.setting-row-top {
  padding-top: 40rpx;
}

.setting-row-bottom {
  padding-bottom: 40rpx;
}

.setting-text {
  font-size: 28rpx;
  line-height: 44rpx;
}

.setting-icon {
  width: 44rpx;
  height: 44rpx;
}
