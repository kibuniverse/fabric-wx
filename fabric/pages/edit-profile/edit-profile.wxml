<view class="container">
  <!-- 头像区域（点击头像或文字都可更换） -->
  <button class="avatar-btn-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
    <view class="avatar-section">
      <image wx:if="{{avatarLoading}}" class="avatar avatar-placeholder" src="/assets/default_avatar.jpg" mode="aspectFill" />
      <image wx:else class="avatar" src="{{avatarUrl || '/assets/default_avatar.jpg'}}" mode="aspectFill" />
    </view>
    <text class="change-avatar-text">更换头像</text>
  </button>

  <!-- 用户信息卡片 -->
  <view class="info-card">
    <view class="info-row" bindtap="onEditNickname">
      <text class="info-label">用户名</text>
      <view class="info-value">
        <text class="nickname-text">{{nickName}}</text>
        <dynamic-svg svg-class="arrow-icon" svgPath="/assets/go.svg" color="rgba(51, 51, 51, 0.6)" />
      </view>
    </view>
    <view class="info-row" bindtap="onViewZhizhiId">
      <text class="info-label">知织ID</text>
      <view class="info-value">
        <text class="zhizhi-id-text">{{zhizhiId}}</text>
        <dynamic-svg wx:if="{{!zhizhiIdModified}}" svg-class="arrow-icon" svgPath="/assets/go.svg" color="rgba(51, 51, 51, 0.6)" />
      </view>
    </view>
  </view>
</view>