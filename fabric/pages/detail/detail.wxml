<!-- pages/detail/detail.wxml -->
<view class="detail-container">

  <!-- 计数器区域 -->
  <view class="counter-section">
    <simple-counter
      id="detail-counter"
      counterId="{{itemId}}"
      backgroundColor="transparent"
      enableVibration="{{isVibrationOn}}"
      enableVoice="{{isVoiceOn}}"
      linked="{{rulerCounterLinked && rulerVisible}}"
      bind:increase="onCounterIncrease"
      bind:decrease="onCounterDecrease"
      bind:up="onCounterUp"
      bind:down="onCounterDown"
    ></simple-counter>
    <!-- 编辑态：覆盖计数器区域，点击退出编辑态 -->
    <view
      wx:if="{{rulerVisible && rulerIsEditMode}}"
      class="counter-section-edit-overlay"
      catchtap="onRulerExitEditMode"
      catchtouchmove=""
    />
  </view>

  <!-- 图解预览区域 -->
  <view class="preview-area">
    <!-- 图片预览：swiper + 手势缩放 -->
    <block wx:if="{{itemType === 'image' || (itemType === 'pdf' && itemPaths.length > 0)}}">
      <!-- 统一的手势处理容器 -->
      <view
        class="swiper-wrapper"
        catchtouchstart="onTouchStart"
        catchtouchmove="onTouchMove"
        catchtouchend="onTouchEnd"
      >
        <!-- 正常状态：swiper 滑动 -->
        <swiper
          class="image-swiper"
          current="{{currentImageIndex}}"
          duration="{{300}}"
          bindchange="onSwiperChange"
          hidden="{{scale > 1 || isAnimating}}"
          style="pointer-events: {{scale > 1 || (rulerVisible && rulerIsEditMode) ? 'none' : 'auto'}};"
        >
          <swiper-item wx:for="{{itemPaths}}" wx:key="index">
            <view class="image-container">
              <image
                src="{{item}}"
                mode="aspectFit"
                class="preview-image {{isAnimating ? 'animating' : ''}}"
                bindload="onImageLoad"
                bindtap="onImageTap"
              />
            </view>
          </swiper-item>
        </swiper>
        <!-- 缩放图片层（始终渲染，缩放/动画时可见） -->
        <view class="scaled-image-container" hidden="{{scale <= 1 && !isAnimating}}">
          <image
            src="{{itemPath}}"
            mode="aspectFit"
            class="preview-image {{isAnimating ? 'animating' : ''}}"
            style="transform: translate({{translateX}}px, {{translateY}}px) scale({{scale}});"
            bindload="onImageLoad"
          />
        </view>
      </view>

      <!-- 编辑态：preview-area 内退出遮罩（拦截图片手势，标尺变换层 z-index 15 在其上方仍可操作） -->
      <view
        wx:if="{{rulerVisible && rulerIsEditMode}}"
        class="ruler-edit-overlay"
        catchtap="onRulerExitEditMode"
        catchtouchmove=""
      />

      <!-- 标尺变换层（与图片共享 transform，跟随缩放/平移） -->
      <view
        wx:if="{{rulerVisible}}"
        class="ruler-transform-layer {{isAnimating ? 'ruler-transform-animating' : ''}}"
        style="transform: translate({{translateX}}px, {{translateY}}px) scale({{scale}});"
      >
        <!-- 标尺主体 -->
        <view
          class="ruler-body {{rulerIsEditMode ? 'ruler-body-editing' : ''}} {{rulerType === 'plain' ? 'ruler-body-plain' : ''}} {{rulerAnimating ? 'ruler-animating' : ''}}"
          style="left:{{containerWidth/2 + rulerX}}px;top:{{containerHeight/2 + rulerY}}px;width:{{rulerLength}}px;height:{{rulerThickness}}px;transform:translate(-50%,-50%) rotate({{rulerAngle}}deg);"
          catchtouchstart="onRulerBodyTouchStart"
          catchtouchmove="onRulerTouchMove"
          catchtouchend="onRulerTouchEnd"
        >
          <!-- 刻度线（CSS repeating-gradient 实现，无刻度模式下隐藏） -->
          <view wx:if="{{rulerType === 'ticked'}}" class="ruler-ticks" />

          <!-- 编辑态：侧边手柄（上下各一个，动态定位在可视区，用于调整标尺厚度） -->
          <view wx:if="{{rulerIsEditMode}}">
            <view class="ruler-handle-hit ruler-handle-hit-side-top" style="left:{{rulerSideHandleLeft}}px;" catchtouchstart="onRulerHandleTouchStart" data-handle="sideTop">
              <view class="ruler-handle" />
            </view>
            <view class="ruler-handle-hit ruler-handle-hit-side-bottom" style="left:{{rulerSideHandleLeft}}px;" catchtouchstart="onRulerHandleTouchStart" data-handle="sideBottom">
              <view class="ruler-handle" />
            </view>
          </view>
        </view>

        <!-- 计数器-标尺联动开关 icon（编辑态/旋转时隐藏） -->
        <view
          wx:if="{{!rulerIsEditMode && !rulerShowAngle}}"
          class="ruler-link-icon-wrapper {{rulerAnimating ? 'ruler-animating' : ''}}"
          style="left:{{containerWidth/2 + rulerX}}px;top:{{containerHeight/2 + rulerY}}px;width:{{rulerLength}}px;height:{{rulerThickness}}px;transform:translate(-50%,-50%) rotate({{rulerAngle}}deg);"
        >
          <view
            class="ruler-link-icon {{rulerCounterLinked ? 'ruler-link-icon-active' : ''}} {{rulerAnimating ? 'ruler-animating' : ''}}"
            style="left:{{rulerLinkIconLeft}}px;top:{{rulerLinkIconTop}}px;"
            catchtap="onRulerLinkToggle"
          >
            <image src="/assets/ruler_link.svg" mode="aspectFit" class="ruler-link-img" binderror="onRulerLinkIconError" wx:if="{{!rulerLinkIconFallback}}" />
            <view wx:if="{{rulerLinkIconFallback}}" class="ruler-link-fallback">⇔</view>
          </view>
        </view>
      </view>

      <!-- 双指旋转角度显示（独立层，preview-area 坐标定位，不受 transform 影响） -->
      <view
        wx:if="{{rulerVisible && rulerShowAngle}}"
        class="ruler-angle-display"
        style="left:{{rulerAngleScreenLeft}};top:{{rulerAngleScreenTop}};"
      >
        <text class="ruler-angle-text">{{rulerAngleDisplay}}</text>
      </view>

      <!-- 标尺联动提示·聚光灯（首次拖动标尺后展示，阻挡其他操作直到点击"我知道了"） -->
      <view wx:if="{{showRulerLinkTip}}" class="ruler-link-tip-overlay" catchtouchstart="" catchtouchmove="" catchtap="">
        <!-- 透明圆圈 + 巨型 box-shadow 遮挡周围，形成聚光灯效果 -->
        <view class="ruler-link-tip-spotlight" style="left:{{rulerLinkTipLeft}};top:{{rulerLinkTipTop}};" />
        <!-- 说明文字 + 按钮，居中显示 -->
        <view class="ruler-link-tip-card">
          <text class="ruler-link-tip-text">计数器可以和标尺联动，快试试吧～</text>
          <view class="ruler-link-tip-confirm" catchtap="onRulerLinkTipDismiss">我知道了</view>
        </view>
      </view>

      <!-- 页码指示器 -->
      <view wx:if="{{totalImages > 1 && scale <= 1}}" class="page-indicator">
        <text>{{currentImageIndex + 1}}/{{totalImages}}页</text>
      </view>

      <!-- PDF转换小进度（右上角，不遮挡操作） -->
      <view wx:if="{{pdfConvertProgress}}" class="pdf-convert-progress">
        <view class="pdf-convert-spinner" />
        <text class="pdf-convert-text">{{pdfConvertProgress}}页</text>
      </view>
    </block>

    <!-- PDF转换中 -->
    <view wx:elif="{{itemType === 'pdf' && isConverting}}" class="loading-state">
      <text>正在转换PDF...</text>
    </view>

    <!-- 加载中 -->
    <view wx:else class="loading-state">
      <text>加载中...</text>
    </view>

    <!-- 浮动按钮组 -->
    <view
      class="detail-fab-group {{isFabCollapsed && !isFabDragging ? 'fab-collapsed' : ''}}"
      style="{{fabAnimStyle || ''}}"
      bindtouchstart="onFabTouchStart"
      catchtouchmove="onFabTouchMove"
      bindtouchend="onFabTouchEnd"
    >
      <view class="detail-fab-handle" catchtap="onFabCollapse">
        <view class="detail-fab-handle-dot" />
        <view class="detail-fab-handle-dot" />
        <view class="detail-fab-handle-dot" />
        <view class="detail-fab-handle-dot" />
        <view class="detail-fab-handle-dot" />
        <view class="detail-fab-handle-dot" />
      </view>
      <!-- 临时计数 -->
      <view class="detail-fab-item" bindtap="onTempCounterTap">
        <image class="detail-fab-icon detail-fab-icon-counter" src="/assets/temp_counter.svg" mode="aspectFit" />
        <text class="detail-fab-label">临时计数</text>
      </view>
      <!-- 针织笔记 -->
      <view class="detail-fab-item" bindtap="onMemoFabTap">
        <image class="detail-fab-icon detail-fab-icon-note" src="/assets/note.svg" mode="aspectFit" />
        <text class="detail-fab-label">针织笔记</text>
      </view>
      <!-- 标记工具 -->
      <view class="detail-fab-item" bindtap="onPaintFabTap">
        <image class="detail-fab-icon detail-fab-icon-paint" src="/assets/paint.svg" mode="aspectFit" />
        <text class="detail-fab-label">标记工具</text>
      </view>
    </view>

    <!-- 收起时展开按钮 -->
    <view
      class="fab-expand-btn {{isFabCollapsed ? 'fab-expand-visible' : ''}}"
      catchtap="onFabExpand"
    >
      <image src="/assets/expand.svg" mode="aspectFit" style="width:54rpx;height:80rpx;" />
    </view>
  </view>

  <!-- 临时计数器底部栏 -->
  <!-- 拖拽时透明遮罩，点击关闭删除按钮 -->
  <view wx:if="{{showDeleteForId}}" class="temp-counter-overlay {{showPaintToolbar || rulerIsEditMode ? 'temp-counter-overlay-hidden' : ''}}" bindtap="onDismissDelete" />

  <view
    wx:for="{{tempCounters}}"
    wx:key="id"
    class="temp-counter-item {{draggingCounterId === item.id && didDrag ? 'dragging' : ''}} {{showPaintToolbar || rulerIsEditMode ? 'temp-counter-hidden' : ''}}"
    style="left:{{item.x}}px;top:{{item.y}}px;z-index:{{draggingCounterId === item.id && didDrag ? 999 : (200 + item.zOrder)}};"
    bindtouchstart="onTempCounterTouchStart"
    catchtouchmove="onTempCounterDragMove"
    bindtouchend="onTempCounterDragEnd"
    data-id="{{item.id}}"
  >
    <!-- 删除按钮（编辑态） -->
    <view wx:if="{{showDeleteForId}}" class="temp-counter-delete" catchtap="onTempCounterDelete" data-id="{{item.id}}">
      <image src="/assets/temp_conter_delete.svg" mode="aspectFit" />
    </view>
    <!-- 重置按钮（非编辑态） -->
    <view wx:if="{{!showDeleteForId && item.count > 0}}" class="temp-counter-reset" catchtap="onTempCounterReset" data-id="{{item.id}}">
      <image src="/assets/tem_counter_clear.svg" mode="aspectFit" />
    </view>
    <!-- icon（点击切换颜色） -->
    <image
      class="temp-counter-frame"
      src="{{item.isActive ? '/assets/temp_connect_active.svg' : '/assets/temp_connect.svg'}}"
      mode="aspectFit"
      catchtap="onTempCounterIconTap"
      data-id="{{item.id}}"
    />
    <!-- [-] 数字 [+] -->
    <view class="temp-counter-row">
      <view class="temp-counter-btn {{showDeleteForId ? 'temp-counter-btn-disabled' : ''}}" hover-class="{{showDeleteForId ? '' : 'temp-counter-btn-hover'}}" hover-stay-time="100" catchtap="{{showDeleteForId ? '' : 'onTempCounterDecrease'}}" data-id="{{item.id}}">
        <image src="/assets/minus.svg" mode="aspectFit" />
      </view>
      <text class="temp-counter-value" catchtap="{{showDeleteForId ? '' : 'onTempCounterValueTap'}}" data-id="{{item.id}}">{{item.count}}</text>
      <view class="temp-counter-btn {{showDeleteForId ? 'temp-counter-btn-disabled' : ''}}" hover-class="{{showDeleteForId ? '' : 'temp-counter-btn-hover'}}" hover-stay-time="100" catchtap="{{showDeleteForId ? '' : 'onTempCounterIncrease'}}" data-id="{{item.id}}">
        <image src="/assets/plus.svg" mode="aspectFit" />
      </view>
    </view>
    <text class="temp-counter-item-label" catchtap="onTempCounterLabelTap" data-id="{{item.id}}">{{item.name || '临时计数'}}</text>

    <!-- Tip 1: 同步开关引导（在 icon 上方） -->
    <view wx:if="{{showTempCounterTipStep === 1 && item.id === tempCounterTipTargetId}}" class="temp-counter-tip tip-sync" catchtouchstart="" catchtouchend="" catchtap="">
      <text class="temp-counter-tip-text">打开同步开关，可以和主计数器同步操作</text>
      <view class="temp-counter-tip-btn" catchtap="onTempCounterTipDismiss" data-step="{{1}}">我知道了</view>
      <view class="temp-counter-tip-arrow tip-sync-arrow"></view>
    </view>

    <!-- Tip 2: 长按删除引导（在计数器上方） -->
    <view wx:if="{{showTempCounterTipStep === 2 && item.id === tempCounterTipTargetId}}" class="temp-counter-tip tip-delete" catchtouchstart="" catchtouchend="" catchtap="">
      <text class="temp-counter-tip-text-inline">长按可以删除临时计数器</text>
      <text class="temp-counter-tip-btn-inline" catchtap="onTempCounterTipDismiss" data-step="{{2}}">我知道了</text>
      <view class="temp-counter-tip-arrow tip-delete-arrow"></view>
    </view>
  </view>

  <!-- 标记工具栏 -->
  <view
    wx:if="{{showPaintToolbar}}"
    class="paint-sheet"
    style="{{paintSheetStyle || ''}}"
    bindtouchstart="onPaintSheetTouchStart"
    catchtouchmove="onPaintSheetTouchMove"
    bindtouchend="onPaintSheetTouchEnd"
    bind:transitionend="onPaintSheetTransitionEnd"
  >
    <view class="paint-toolbar">
      <!-- 下滑关闭把手（内嵌在工具栏顶部） -->
      <view class="paint-drag-handle"></view>
      <!-- 三个工具（水平居中） -->
      <view class="paint-tools">
        <!-- 记号笔（暂时注释）
        <view class="paint-tool-item" bindtap="onPaintToolSelect" data-tool="highlighter">
          <image
            src="/assets/tool_highlighter.svg"
            mode="aspectFit"
            class="paint-tool-icon {{paintActiveTool === 'highlighter' ? 'paint-tool-active' : ''}}"
          />
        </view>
        -->
        <!-- 橡皮擦（暂时注释）
        <view class="paint-tool-item" bindtap="onPaintToolSelect" data-tool="eraser">
          <image
            src="/assets/tool_eraser.svg"
            mode="aspectFit"
            class="paint-tool-icon {{paintActiveTool === 'eraser' ? 'paint-tool-active' : ''}}"
          />
        </view>
        -->
        <view class="paint-tool-item paint-tool-ruler" bindtap="onPaintToolSelect" data-tool="ruler" bindlongpress="onRulerToolLongPress">
          <image
            src="/assets/tool_ruler.svg"
            mode="aspectFit"
            class="paint-tool-icon {{paintActiveTool === 'ruler' ? 'paint-tool-active' : ''}}"
          />
        </view>
      </view>
      <!-- 右侧：redo在左，undo在右（暂时注释）
      <view class="paint-history-btns">
        <view class="paint-history-btn {{!hasHighlighterHistory ? 'paint-history-btn-disabled' : ''}}" hover-class="{{hasHighlighterHistory ? 'paint-history-btn-hover' : ''}}" hover-stay-time="100" bindtap="onPaintRedo">
          <image src="/assets/redo.svg" mode="aspectFit" style="width:40rpx;height:40rpx;" />
        </view>
        <view class="paint-history-btn {{!hasHighlighterHistory ? 'paint-history-btn-disabled' : ''}}" hover-class="{{hasHighlighterHistory ? 'paint-history-btn-hover' : ''}}" hover-stay-time="100" bindtap="onPaintUndo">
          <image src="/assets/undo.svg" mode="aspectFit" style="width:40rpx;height:40rpx;" />
        </view>
      </view>
      -->
      <!-- 标尺长按提示（首次打开工具栏时展示） -->
      <view wx:if="{{showRulerLongPressTip}}" class="ruler-longpress-tip" catchtouchstart="" catchtouchmove="" catchtap="">
        <view class="ruler-longpress-tip-content">
          <text>长按可以更换标尺类型～</text>
          <text class="ruler-longpress-tip-confirm" catchtap="onRulerLongPressTipDismiss">我知道了</text>
        </view>
        <view class="ruler-longpress-tip-arrow"></view>
      </view>
    </view>
  </view>

  <!-- 标尺类型切换 Tips 遮罩（触摸外部关闭） -->
  <view wx:if="{{showRulerTypeTip}}" class="ruler-type-dismiss-overlay" catchtouchstart="onRulerTypeTipDismiss" catchtouchmove="" />
  <!-- 标尺类型切换 Tips -->
  <view wx:if="{{showRulerTypeTip}}" class="ruler-type-tip" style="left:{{rulerTypeTipX}};top:{{rulerTypeTipY}};transform:translate(-50%,-100%);" catchtouchstart="" catchtouchmove="" catchtap="">
    <view class="ruler-type-track">
      <view class="ruler-type-slider" style="transform: translateX({{rulerType === 'plain' ? '100%' : '0'}});" />
      <view class="ruler-type-option" catchtap="onRulerTypeSelect" data-type="ticked">有刻度</view>
      <view class="ruler-type-option" catchtap="onRulerTypeSelect" data-type="plain">无刻度</view>
    </view>
    <view class="ruler-type-tip-arrow" />
  </view>

</view>