/* pages/detail/detail.wxss */
.detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
}

/* 图解预览区域样式 */
.preview-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  overflow: hidden;
  position: relative;
}

/* Swiper 容器 */
.image-swiper {
  width: 100%;
  height: 100%;
}

/* Swiper 包装器（用于手势检测） */
.swiper-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 图片容器 */
.image-container {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  touch-action: none;
  -webkit-user-select: none;
  user-select: none;
}

/* 图片样式 */
.preview-image {
  width: 100%;
  height: 100%;
  will-change: transform;
  -webkit-touch-callout: none;
  -webkit-user-drag: none;
  -webkit-tap-highlight-color: transparent;
  transition: none;
}

/* 动画状态 */
.preview-image.animating {
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* PDF预览 */
.preview-pdf {
  width: 100%;
  height: 100%;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
}

/* 计数器区域 */
.counter-section {
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  background-color: var(--main-bg-color);
}

/* 页码指示器 */
.page-indicator {
  position: absolute;
  top: 44rpx;
  right: 44rpx;
  background-color: rgba(230, 230, 250, 0.7);
  color: #6A0DAD;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  pointer-events: none;
}