<view class="container" style="padding-top: {{inputTop}}px;">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="onBack">
        <t-icon name="chevron-left" size="48rpx" color="#333333" />
      </view>
      <text class="nav-title">修改名字</text>
    </view>
  </view>

  <!-- 输入框区域 -->
  <view class="input-wrapper">
    <view class="input-row">
      <view class="input-field">
        <input
          class="nickname-input"
          type="text"
          placeholder="请输入用户名"
          value="{{nickName}}"
          bindinput="onInputChange"
          bindfocus="onInputFocus"
          maxlength="20"
          cursor="{{cursor}}"
        />
        <text class="char-count">{{nickName.length}}/20</text>
      </view>
      <view class="save-btn" bindtap="onSave">保存</view>
    </view>
  </view>
</view>