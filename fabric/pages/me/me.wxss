.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 356rpx;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* 提示文案 - Medium 20pt */
.tip-text {
  font-size: 40rpx;
  font-weight: 500;
  color: #000;
  margin-bottom: 256rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像 80*80dp = 160rpx */
.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 28rpx;
  color: #999;
}

/* 昵称距离头像 12dp = 24rpx */
.nickname {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: #000;
}

/* 登录按钮：距离昵称 70dp = 140rpx，距离两侧 24dp = 48rpx，圆角 8dp = 16rpx，高 46dp = 92rpx */
.login-btn {
  width: calc(100% - 96rpx);
  height: 92rpx;
  background: #A889C8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 140rpx;
}

/* 登录文案 fontsize 16pt = 32rpx */
.login-btn text {
  color: #fff;
  font-size: 32rpx;
}

/* 协议区域距离按钮底部 16dp = 32rpx */
.agreement {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  flex-wrap: wrap;
  justify-content: center;
  padding: 0 40rpx;
}

/* 复选框外层容器，用于扩大热区 */
.checkbox-wrapper {
  padding: 16rpx;
  margin-right: -6rpx;
}

/* 复选框 12*12dp = 24rpx，描边 2dp = 4rpx，颜色 D9D9D9 */
.checkbox {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #D9D9D9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #A889C8;
  border-color: #A889C8;
}

.check-icon {
  color: #fff;
  font-size: 18rpx;
  line-height: 1;
}

/* 已阅读并同意... fontsize 12pt = 24rpx，颜色 40%黑 */
.agreement-text {
  color: #00000066;
  font-size: 24rpx;
}

.link {
  color: #576B95;
  font-size: 24rpx;
}