/* pages/edit/edit.wxss */
.edit-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #ffffff;
  padding-bottom: 140rpx; /* 为底部保存按钮留出空间 */
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background-color: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #333333;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.nav-placeholder {
  width: 60rpx;
}

/* 图片网格 */
.images-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

.image-item {
  width: calc(33.33% - 20rpx);
  margin: 10rpx;
  height: 200rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s ease-out, opacity 0.2s ease-out;
}

/* 拖动中的源图片（透明占位） */
.image-item.dragging-source {
  opacity: 0.3;
}

/* 拖动浮层 */
.drag-float {
  position: fixed;
  z-index: 1000;
  pointer-events: none;
  transform: scale(1.05);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
}

.float-image {
  width: 100%;
  height: 100%;
  opacity: 0.9;
}

.float-index {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.image-content {
  width: 100%;
  height: 100%;
}

.image-index {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 占位图 */
.placeholder {
  width: calc(33.33% - 20rpx);
  margin: 10rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #cccccc;
  border-radius: 12rpx;
  background-color: #ffffff;
}

.placeholder-icon {
  font-size: 60rpx;
  color: #cccccc;
  line-height: 1;
}

.placeholder-text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 删除区域 */
.delete-zone {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
  border-top: 2rpx solid #dddddd;
  transition: background-color 0.2s;
  z-index: 999;
}

.delete-zone.active {
  background-color: #ff4d4f;
  animation: shake 0.3s ease-in-out;
}

.delete-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.delete-text {
  font-size: 28rpx;
  color: #666666;
}

.delete-zone.active .delete-text {
  color: #ffffff;
}

/* 底部保存按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.bottom-bar .save-btn {
  width: 100%;
  height: 72rpx;
  background-color: #A889C8;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 抖动动画 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

/* 对话框内容 */
.dialog-content {
  padding: 20rpx;
  font-size: 28rpx;
  color: #666666;
  text-align: center;
}