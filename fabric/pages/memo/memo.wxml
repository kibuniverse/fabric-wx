<view class="memo-page">
  <view class="memo-header">
    <view class="header-info" wx:if="{{lastModified}}">
      <text class="last-modified">上次修改：{{lastModified}}</text>
    </view>
  </view>
  <view class="clear-btn" wx:if="{{content}}" bindtap="handleClear">清空</view>
  <textarea class="memo-content" placeholder="在这里记录一下吧～" value="{{content}}" bindinput="handleInput" maxlength="-1" auto-height />
</view>