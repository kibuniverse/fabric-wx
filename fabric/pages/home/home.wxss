/* pages/home/home.wxss */
.home_container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
  background-color: #FFFFFF;
}
/* 顶部标签导航栏 - 无底部浅灰横线、tab居中 */
.tab-header {
  display: flex;
  position: relative;
  justify-content: center;
  align-items: center;
  padding: 12rpx 30rpx;
  background-color: #FFFFFF;
  justify-content: center;
}
.tab {
  position: relative;
  padding: 12rpx 0 12rpx; /* 底部padding设为6px，为下划线留出间距 */
}
.tab text {
  font-size: 32rpx;
  color: #666;
  display: inline-block; /* 让文字高度可计算 */
  line-height: 1; /* 重置行高，避免行高干扰间距 */
}
.tab.active text {
  font-weight: 500;
  font-size: 32rpx;
  line-height: 44rpx;
  letter-spacing: -0.43px;
  color: #A889C8CC;
}
.tab-line {
  position: absolute;
  bottom: 0; /* 与文字底部间距12rpx */
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #A889C8CC;
  border-radius: 4rpx;
  transition: width 0.3s;
}
/* 加号按钮容器 - 22×22rpx图标适配 */
.add-btn {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-icon {
  width: 44rpx;
  height: 44rpx;
  /* tint-color: #A889C8CC; 可选：修改SVG颜色 */
}
/* 导入选项弹出层 */
.import-options {
  position: absolute;
  top: 80rpx;
  right: 30rpx;
  width: 240rpx;
  background-color: #f5f1ff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
  opacity: 0;
  transform: translateY(-20rpx);
  visibility: hidden;
  transition: all 0.3s;
}
.import-options.show {
  opacity: 1;
  transform: translateY(0);
  visibility: visible;
}
.import-option {
  padding: 20rpx;
  display: flex;
  align-items: center;
}
.option-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}
.import-option text {
  font-size: 28rpx;
  color: #333;
}

.tab-content {
  height: 100%;
}
.content-area {
  flex: 1;
  overflow-y: auto;
}
.empty-state {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}
/* 空状态图片 - 保留420×420，新增兜底居中 */
.empty-diagram {
  width: 420rpx;
  height: 420rpx;
  object-fit: contain;
}
/* 合并图解和文件网格 */
.items-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: 52rpx;
  column-gap: 48rpx;
  flex-wrap: wrap;
  padding: 40rpx;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom) + 44rpx);
}
.item {
  width: 100%;
  border-radius: 12rpx;
  position: relative;
}
.flip-item {
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}


.type-logo {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 32rpx;
  height: 32rpx;
  z-index: 2;
}
.cover-wrapper {
  width: 100%;
  height: 240rpx;
  position: relative;
  border-radius: 8rpx;
}
.default-illustration {
  width: 100%;
  height: 240rpx;
  display: block;
  border-radius: 8rpx;
}
.cover-border-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 8rpx;
  box-shadow: inset 0 0 0 1rpx #E6E6FA;
  z-index: 3;
}
.item-info {
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: absolute;
  bottom: 0;
  background-color: var(--main-color);
  width: 100%;
  border-bottom-left-radius: 8rpx;
  border-bottom-right-radius: 8rpx;
  z-index: 2;
}
.item-name {
  font-size: 26rpx;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 0 12rpx;
}

.item-operate-container {
  display: flex;
  justify-content: space-between;
  height: 48rpx;
  align-items: center;
  padding-left: 0;
  position: relative;
}
.item-type {
  font-size: 20rpx;
  color: #999;
  padding: 4rpx 8rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  margin-left: auto;
}

.more-action {
  height: 48rpx;
  width: 48rpx;
}
/* 遮罩层 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 5;
  visibility: hidden;
}
.mask.show {
  visibility: visible;
}
/* 重命名输入框 */
.rename-input {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin: 20rpx 0;
  box-sizing: border-box;
}
/* 命名提示文字 */
.name-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}
/* 删除弹窗内容 */
.delete-modal-content {
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
}
/* 三个点栏目样式 */
.image-more,
.file-more {
  font-size: 28rpx;
  color: #A889C8CC;
  width: 60rpx;
  text-align: center;
  padding: 0 10rpx;
}

/* 重复文件高亮样式 */
.cover-border-overlay.highlight {
  animation: highlight-pulse 1s ease-in-out 2;
}

@keyframes highlight-pulse {
  0%, 100% {
    box-shadow: inset 0 0 0 1rpx #E6E6FA, 0 0 2rpx 0 rgba(168, 137, 200, 0);
  }
  50% {
    box-shadow: inset 0 0 0 1rpx #E6E6FA, 0 0 2rpx 4rpx rgba(168, 137, 200, 0.5);
  }
}

.item-date {
  font-size: 18rpx;
  color: rgba(51, 51, 51, 0.5);
}

.sync-status-icon {
  width: 30rpx;
  height: 30rpx;
}

/* 同步中旋转动画 */
.sync-loading-icon {
  width: 30rpx;
  height: 30rpx;
  animation: sync-spin 1s linear infinite;
}

@keyframes sync-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.sync-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

/* 同步 Tips 提示样式 */
.sync-tips {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.sync-tips-content {
  background-color: #333;
  color: #fff;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  position: relative;
  white-space: nowrap;
}

.sync-tips-text {
  font-size: 22rpx;
}

.sync-tips-btn {
  font-size: 22rpx;
  color: #A889C8;
  padding: 4rpx 12rpx;
}

/* 小箭头指向下方 */
.sync-tips-content::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 10rpx solid #333;
}

/* 登录引导弹窗内容 */
.login-dialog-content {
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

/* 同步按钮样式 */
.sync-btn {
  font-size: 20rpx;
  color: #A889C8;
  padding: 4rpx 12rpx;
  background-color: #f5f1ff;
  border-radius: 8rpx;
  margin-left: auto;
  margin-right: 8rpx;
}

/* ========== 下拉刷新演示动画 ========== */
.refresh-demo-area {
  height: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-demo-area.refresh-demo {
  animation: refresh-expand 3s ease-in-out forwards;
}

.refresh-demo-text {
  color: rgba(168, 137, 200, 0.8);
  font-size: 26rpx;
  white-space: nowrap;
}

@keyframes refresh-expand {
  0% { height: 0; opacity: 0; }
  25% { height: 100rpx; opacity: 1; }
  65% { height: 100rpx; opacity: 1; }
  100% { height: 0; opacity: 0; }
}