<!-- pages/home/home.wxml -->
<wxs src="../../utils/filters.wxs" module="filters" />
<view class="home_container">
  <!-- 顶部标题栏 -->
  <view class="tab-header">
    <view class="tab active">
      <text>我的图解</text>
      <view class="tab-line active"></view>
    </view>
    <!-- 右上角加号按钮 -->
    <view class="add-btn" bindtap="toggleImportOptions">
      <image class="add-icon" src="/assets/add_diagram.svg" mode="aspectFit"></image>
    </view>
  </view>
  <!-- 导入选项弹出层 -->
  <view class="import-options {{showImportOptions ? 'show' : ''}}">
    <view class="import-option" bindtap="chooseImage">
      <image class="option-icon" src="/assets/image.svg" mode="aspectFit"></image>
      <text>导入图片</text>
    </view>
    <view class="import-option" bindtap="choosePDF">
      <image class="option-icon" src="/assets/pdf_logo.svg" mode="aspectFit"></image>
      <text>导入PDF</text>
    </view>
  </view>
  <!-- 内容区域 -->
  <view class="content-area">
    <!-- 我的图解内容 -->
    <view class="tab-content">
      <block wx:if="{{allItems.length === 0}}">
        <view class="empty-state">
          <image class="empty-diagram" src="/assets/empty_diagram.png" mode="aspectFit"></image>
        </view>
      </block>
      <block wx:else>
        <view class="items-grid">
          <view class="item" wx:for="{{allItems}}" wx:key="id" bindtap="navigateToDetail" data-id="{{item.id}}">
            <image class="default-illustration {{item.id === highlightItemId ? 'highlight' : ''}}" src="{{item.cover || '/assets/default_Illustration.png'}}" mode="aspectFill"></image>
            <image class="type-logo" src="/assets/{{item.type === 'image' ? 'image' : 'pdf_logo'}}.svg"></image>
            <view class="item-info">
              <text class="item-name">{{item.name}}</text>
            </view>
            <view class="item-operate-container" catchtap="showActionSheet" data-id="{{item.id}}" data-type="{{item.type}}">
              <text class="item-date">{{item.createTime ? filters.formatDate(item.createTime) : ''}}</text>
              <image src="/assets/more_action.svg" class="more-action" mode="aspectFill" />
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
  <!-- 遮罩层 -->
  <view class="mask {{showImportOptions ? 'show' : ''}}" bindtap="toggleImportOptions"></view>
  <!-- WeUI ActionSheet -->
  <action-sheet show="{{showActionSheet}}" actions="{{actions}}" bind:actiontap="handleActionClick" bind:close="closeActionSheet" />
  <!-- 重命名对话框 -->
  <mp-dialog title="重命名" show="{{showRenameModal}}" bindbuttontap="handleRenameDialogButtonClick" buttons="{{renameButtons}}">
    <view>
      <input class="rename-input" type="text" value="{{newItemName}}" bindinput="onRenameInput" placeholder="请输入新名称" />
    </view>
  </mp-dialog>
  <!-- 删除确认对话框 -->
  <mp-dialog title="确认删除" show="{{showDeleteModal}}" bindbuttontap="handleDeleteDialogButtonClick" buttons="{{deleteButtons}}">
    <view class="delete-modal-content">确定要删除该项吗？此操作无法撤销。</view>
  </mp-dialog>
  <!-- 命名对话框（导入图片时使用） -->
  <mp-dialog title="命名图解" show="{{showNameModal}}" bindbuttontap="handleNameDialogButtonClick" buttons="{{nameButtons}}">
    <view>
      <view class="name-hint">已选择 {{pendingImages.length}} 张图片</view>
      <input class="rename-input" type="text" value="{{diagramName}}" bindinput="onNameInput" placeholder="请输入图解名称" />
    </view>
  </mp-dialog>
  <!-- 登录引导弹窗 -->
  <mp-dialog title="登录后继续上传" show="{{showLoginPrompt}}" bindbuttontap="handleLoginDialogButtonClick" buttons="{{loginButtons}}">
    <view class="login-dialog-content">登录后上传更多图解，并同步数据～</view>
  </mp-dialog>
</view>